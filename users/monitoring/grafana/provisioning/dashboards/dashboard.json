{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "title": "Rate (R): Requests per minute",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_count[1m]))",
          "legendFormat": "Total requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Errors (E): 4xx vs 5xx",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_count{status_code=~\"4.*\"}[1m]))",
          "legendFormat": "4xx errors",
          "refId": "A"
        },
        {
          "expr": "sum(increase(http_request_duration_seconds_count{status_code=~\"5.*\"}[1m]))",
          "legendFormat": "5xx errors",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "targets": [
        {
          "expr": "(sum(rate(http_request_duration_seconds_count{status_code=~\"4.*|5.*\"}[1m])) / sum(rate(http_request_duration_seconds_count[1m]))) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "min": 0,
          "max": 100
        },
        {}
      ]
    },
    {
      "title": "Throughput (RPS)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Duration (D): Request latency",
      "type": "graph",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(http_request_duration_seconds_bucket[30s])) by (le, route))",
          "legendFormat": "p90 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket[30s])) by (le, route))",
          "legendFormat": "p50 {{route}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_request_duration_seconds_sum[30s])) by (route) / sum(rate(http_request_duration_seconds_count[30s])) by (route)",
          "legendFormat": "avg {{route}}",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "s",
          "min": 0
        },
        {}
      ]
    }
  ],
  "schemaVersion": 25,
  "style": "dark",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "title": "Service Dashboard",
  "version": 1
}